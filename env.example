# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — copy this file to .env and fill in all values.
# Variables marked [REQUIRED] must be set; [OPTIONAL] have sensible defaults.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development                      # development | production
PORT=5001                                 # [OPTIONAL] defaults to 5001
LOG_LEVEL=debug                           # [OPTIONAL] debug | info | warn | error

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ── Frontend / CORS ───────────────────────────────────────────────────────────
# Primary frontend URL (used for CORS and Socket.io origin)
FRONTEND_URL=http://localhost:5173
# Comma-separated list of additional allowed origins (e.g. custom domain, CDN)
# EXTRA_ALLOWED_ORIGINS=https://myapp.com,https://www.myapp.com

# ── Cloudinary (media uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Google Generative AI (Gemini) ─────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# ── Email (SMTP via Nodemailer) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-digit-app-password      # Gmail app password (not your login password)
SMTP_FROM=your.email@gmail.com
